# Variables de Entorno - Copia este archivo como .env y cambia los valores
# IMPORTANTE: Nunca subas el archivo .env a Git

# Clave secreta de Flask (genera una aleatoria con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production

# Usuario protegido
PROTECTED_USERNAME=dajhanchi
PROTECTED_USER_SECRET=tu-clave-super-secreta-aqui

